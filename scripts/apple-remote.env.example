# Copy this file to .apple-remote.env and adjust for your Mac.

APPLE_REMOTE_HOST=mac-mini
APPLE_REMOTE_PATH=/Users/gabrielalonso/dev/sidescreen-linux-mirror
APPLE_REMOTE_DERIVED_DATA=
APPLE_REMOTE_PATH_PREFIX=/opt/homebrew/bin:/usr/local/bin
APPLE_REMOTE_CONNECT_TIMEOUT=10
APPLE_REMOTE_RSYNC_PROTOCOL=29

MACOS_PACKAGE_DIR=MacHost
MACOS_CONFIGURATION=debug
MACOS_RUN_TESTS=1
MACOS_RUN_SWIFTLINT=1

# Leave MACOS_PROJECT/MACOS_SCHEME empty for Swift Package projects.
# Fill both for Xcode projects.
MACOS_PROJECT=
MACOS_SCHEME=
MACOS_DESTINATION=platform=macOS,arch=arm64
MACOS_DERIVED_DATA=
MACOS_BUILD_PRODUCTS_DIR=/tmp/sidescreen-xcode-products/macos
MACOS_PARALLEL_TESTING_ENABLED=NO
MACOS_CODE_SIGNING_ALLOWED=NO
MACOS_CODE_SIGNING_REQUIRED=NO

IOS_SIMULATOR_NAME="iPhone 17"
IOS_PROJECT=
IOS_SCHEME=
IOS_DERIVED_DATA=
